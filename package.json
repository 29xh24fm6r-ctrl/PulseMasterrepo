    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.5.1",
    "resend": "^6.5.2",
    "sonner": "^2.0.7",
    "stripe": "^20.0.0",
    "swr": "^2.3.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",

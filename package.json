    "test:mythic": "tsx scripts/test-mythic-end-to-end.ts",
    "check:shell": "node scripts/check-shell-ownership.mjs",
    "verify:shell": "node scripts/verify-shell.mjs",
    "guard:no-service-role": "node scripts/guards/guard-no-service-role.js",
    "guard:no-notion-runtime": "node scripts/guards/guard-no-notion-runtime.js",
    "guard:user-id-uuid": "node scripts/guards/guard-user-id-uuid.js",
    "guard:no-internal-http": "node scripts/guards/guard-no-internal-http.js",
    "guard": "npm run guard:no-service-role && npm run guard:no-notion-runtime && npm run guard:user-id-uuid && npm run guard:no-internal-http",
    "contracts:check": "node scripts/contracts-check.mjs",
    "contracts:strict": "node scripts/contracts-strict-check.mjs",
    "migrations:check": "node scripts/migrations-check.mjs",
    "orphan:check": "node scripts/orphan-routes-check.mjs",
    "features:gen": "node scripts/generate-feature-registry.mjs",
    "features:check": "node scripts/features-gen-check.mjs",
    "sweeper:check": "node scripts/dead-sweeper-check.mjs",
    "stub:missing-apis": "node scripts/stub-missing-apis.mjs",
    "canary:check": "node scripts/canary-check.mjs"

{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p . --noEmit",
    "audit-tenant": "node scripts/audit-owner-filter.ts",
    "check-tenant-safety": "powershell -ExecutionPolicy Bypass -File scripts/check-tenant-safety.ps1",
